<%- include('layout/header') %>
<%- include('layout/navbar') %>

<header>
    <h1 class="site-heading text-center text-faded d-none d-lg-block">
        <span class="site-heading-upper text-primary mb-3">A Free Bootstrap Business Theme</span>
        <span class="site-heading-lower">Business Casual</span>
    </h1>
</header>

<!-- Navigation (GIỮ hoặc XÓA nếu đã có navbar.ejs) -->
<nav class="navbar navbar-expand-lg navbar-dark py-lg-4">
    <div class="container">
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav mx-auto">
                <!-- SỬA LINK EXPRESS -->
                <li class="nav-item px-lg-4"><a class="nav-link text-uppercase" href="/">Home</a></li>
                <li class="nav-item px-lg-4"><a class="nav-link text-uppercase" href="/contact">About</a></li>
                <li class="nav-item px-lg-4"><a class="nav-link text-uppercase" href="/list">Products</a></li>
                <li class="nav-item px-lg-4"><a class="nav-link text-uppercase" href="/contact">Store</a></li>
            </ul>
        </div>
    </div>
</nav>

<section class="page-section clearfix">
    <div class="container">
        <div class="intro">
            <!-- SỬA ĐƯỜNG DẪN ẢNH -->
            <img class="intro-img img-fluid mb-3 mb-lg-0 rounded" src="/images/intro.jpg" alt="coffee" />

            <div class="intro-text left-0 text-center bg-faded p-5 rounded">
                <h2 class="section-heading mb-4">
                    <span class="section-heading-upper">Fresh Coffee</span>
                    <span class="section-heading-lower">Worth Drinking</span>
                </h2>

                <p class="mb-3">
                    Every cup of our quality artisan coffee starts with locally sourced ingredients.
                </p>

                <div class="intro-button mx-auto">
                    <a class="btn btn-primary btn-xl" href="/contact">Visit Us Today!</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="page-section cta">
    <div class="container">
        <div class="row">
            <div class="col-xl-9 mx-auto">
                <div class="cta-inner bg-faded text-center rounded">
                    <h2 class="section-heading mb-4">
                        <span class="section-heading-upper">Our Promise</span>
                        <span class="section-heading-lower">To You</span>
                    </h2>

                    <p class="mb-0">
                        We are committed to providing the best coffee experience every day.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('layout/footer') %>
